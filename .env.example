# Copy this file to .env and fill in your values.
# .env is gitignored - never commit secrets.

# Ollama Cloud (recommended - larger models on Ollama's servers)
# Get your API key at https://ollama.com/settings/keys
OLLAMA_API_KEY=your_ollama_cloud_key_here

# Optional: model (use gpt-oss:120b for Ollama Cloud)
# OLLAMA_MODEL=gpt-oss:120b

# Optional: host (default: https://ollama.com when API key set, else http://localhost:11434)
# OLLAMA_HOST=https://ollama.com
